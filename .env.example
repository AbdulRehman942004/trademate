# ── server/.env ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/trademate
SECRET_KEY=change-this-to-a-long-random-secret

OPENAI_API_KEY=your-openai-api-key
PINECONE_API_KEY=your-pinecone-api-key

AWS_SES_FROM_EMAIL=your-ses-from-email
AWS_SES_USERNAME=your-ses-username
AWS_SES_PASSWORD=your-ses-password

FREIGHTOS_API_KEY=your-freightos-api-key
FREIGHTOS_API_SECRET=your-freightos-api-secret

MEMGRAPH_URI=bolt://knowledge-graph:7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=

# Set automatically by docker-compose — do not override in server/.env
# REDIS_URL=redis://redis:6379/0
# DATA_PIPELINE_URL=http://data-pipeline:8001
# KNOWLEDGE_GRAPH_URL=http://knowledge-graph:8002
# TIPP_SCRAPER_URL=http://tipp-scraper:8003

# ── data_pipeline/backend/.env ───────────────────────────────────────────────
# AWS_S3_BUCKET_NAME=data-trademate
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1
# PINECONE_API_KEY=your-pinecone-api-key
# OPENAI_API_KEY=your-openai-api-key

# ── knowledge_graph/.env ─────────────────────────────────────────────────────
# MEMGRAPH_URI=bolt://localhost:7687
# MEMGRAPH_USERNAME=
# MEMGRAPH_PASSWORD=
# OPENAI_API_KEY=your-openai-api-key

# ── tipp_scrapping/.env ──────────────────────────────────────────────────────
# PORT=8003
# HOST=0.0.0.0
# DATA_DIR=data
# AWS_S3_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID_MANUAL=your-access-key-id
# AWS_SECRET_ACCESS_KEY_MANUAL=your-secret-access-key
# AWS_REGION=us-east-1
# PROXY_ENABLED=True

# ── client/.env ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SERVER_URL=http://localhost:8000

# ── admin-portal/.env ────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── data_pipeline/frontend/.env ──────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8001
